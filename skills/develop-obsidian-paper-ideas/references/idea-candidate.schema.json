{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appendix A.3 Paper Direction Candidate",
  "type": "object",
  "required": [
    "idea_id", "development_mode", "source_cluster_ids", "knowledge_status",
    "decision_status", "scientific_question", "current_understanding",
    "specific_gap", "falsifiable_judgment", "support_condition",
    "refutation_condition", "minimum_data", "minimum_experiment",
    "innovation_type", "team_fit", "main_risks", "target_output",
    "stop_conditions", "markdown_path", "recommendation", "score_total",
    "fatal_gates", "next_actions", "source_records"
  ],
  "properties": {
    "idea_id": {"type": "string", "minLength": 1},
    "development_mode": {"enum": ["formal", "exploratory"]},
    "source_batch_id": {"type": ["string", "null"]},
    "source_cluster_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "knowledge_status": {"const": "candidate"},
    "decision_status": {"const": "waiting_for_mentor_decision"},
    "scientific_question": {"type": "string", "minLength": 1},
    "current_understanding": {"type": "string", "minLength": 1},
    "specific_gap": {"type": "string", "minLength": 1},
    "falsifiable_judgment": {"type": "string", "minLength": 1},
    "support_condition": {"type": "string", "minLength": 1},
    "refutation_condition": {"type": "string", "minLength": 1},
    "minimum_data": {"type": "object"},
    "minimum_experiment": {"type": "object"},
    "innovation_type": {"enum": ["theory", "method", "understanding", "application"]},
    "team_fit": {"type": "string", "minLength": 1},
    "main_risks": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "target_output": {"type": "string", "minLength": 1},
    "stop_conditions": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "markdown_path": {"type": "string", "minLength": 1},
    "recommendation": {
      "enum": ["建议优先开展", "建议修改后开展", "建议作为附属分析", "暂不建议开展"]
    },
    "score_total": {"type": "integer", "minimum": 8, "maximum": 40},
    "fatal_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["gate", "passed", "evidence_or_reason", "repair"],
        "properties": {
          "gate": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "evidence_or_reason": {"type": "string", "minLength": 1},
          "repair": {"type": "string", "minLength": 1}
        }
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["order", "task", "dependency", "owner", "completion_criterion"],
        "properties": {
          "order": {"type": "integer", "minimum": 1},
          "task": {"type": "string", "minLength": 1},
          "dependency": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "completion_criterion": {"type": "string", "minLength": 1}
        }
      }
    },
    "source_records": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["display_name", "source_path_or_url", "used_content"],
        "properties": {
          "display_name": {"type": "string", "minLength": 1},
          "source_path_or_url": {"type": "string", "minLength": 1},
          "used_content": {"type": "string", "minLength": 1}
        }
      }
    }
  },
  "additionalProperties": true
}
