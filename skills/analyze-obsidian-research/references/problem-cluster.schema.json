{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Appendix A.2 Problem Cluster",
  "type": "object",
  "required": [
    "cluster_id", "cluster_name", "analysis_mode", "knowledge_status",
    "core_contradiction", "supporting_evidence", "limitations_conflicts",
    "current_consensus", "evidence_grade", "unresolved_part",
    "unresolved_type", "china_team_relevance", "minimum_additional_evidence",
    "confidence", "confidence_reason", "resolved_items", "open_questions",
    "testable_hypotheses", "minimum_validation_actions", "cross_paper_comparisons",
    "competing_explanations", "markdown_path", "theme_map_path",
    "paper_interpretations", "source_files", "source_traces"
  ],
  "properties": {
    "cluster_id": {"type": "string", "minLength": 1},
    "cluster_name": {"type": "string", "minLength": 1},
    "analysis_mode": {"enum": ["formal", "exploratory"]},
    "source_batch_id": {"type": ["string", "null"]},
    "knowledge_status": {"enum": ["archive", "candidate", "formal"]},
    "core_contradiction": {"type": "string", "minLength": 1},
    "supporting_evidence": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "limitations_conflicts": {"type": "array", "items": {"type": "string"}},
    "current_consensus": {"type": "string", "minLength": 1},
    "evidence_grade": {"type": "string", "minLength": 1},
    "unresolved_part": {"type": "string", "minLength": 1},
    "unresolved_type": {"enum": ["real_conflict", "validation_gap", "definition_mismatch", "missing_material"]},
    "china_team_relevance": {"type": "string", "minLength": 1},
    "minimum_additional_evidence": {"type": "string", "minLength": 1},
    "confidence": {"enum": ["high", "medium", "low"]},
    "confidence_reason": {"type": "string", "minLength": 1},
    "resolved_items": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}},
    "open_questions": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}},
    "testable_hypotheses": {"type": "array", "minItems": 3, "items": {"type": "string", "minLength": 1}},
    "minimum_validation_actions": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "cross_paper_comparisons": {"type": "array", "minItems": 4, "items": {"type": "string", "minLength": 1}},
    "competing_explanations": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
    "markdown_path": {"type": "string", "minLength": 1},
    "theme_map_path": {"type": "string", "minLength": 1},
    "paper_interpretations": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "canonical_literature_id", "source_title", "source_path_or_url",
          "source_file", "claim_id", "relation_role", "study_object_and_data",
          "method_mechanism", "validation_design", "paper_owned_findings",
          "cluster_interpretation", "boundary_and_verification",
          "evidence_status", "review_status"
        ],
        "properties": {
          "canonical_literature_id": {"type": "string", "minLength": 1},
          "source_title": {"type": "string", "minLength": 1},
          "source_path_or_url": {"type": "string", "minLength": 1},
          "source_file": {"type": "string", "minLength": 1},
          "deep_note_file": {"type": ["string", "null"]},
          "zotero_item_key": {"type": ["string", "null"]},
          "claim_id": {"type": "string", "minLength": 1},
          "relation_role": {"enum": ["supports", "limits", "conflicts", "conditions", "gap_signal", "method_for", "needs_verification"]},
          "study_object_and_data": {"type": "string", "minLength": 40},
          "method_mechanism": {"type": "string", "minLength": 40},
          "validation_design": {"type": "string", "minLength": 40},
          "paper_owned_findings": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["finding", "source_context", "comparison", "metric_observation", "study_condition", "interpretation", "boundary"],
              "properties": {
                "finding": {"type": "string", "minLength": 20},
                "source_context": {"type": "string", "minLength": 1},
                "comparison": {"type": "string", "minLength": 1},
                "metric_observation": {"type": "string", "minLength": 1},
                "study_condition": {"type": "string", "minLength": 1},
                "interpretation": {"type": "string", "minLength": 1},
                "boundary": {"type": "string", "minLength": 1}
              },
              "additionalProperties": true
            }
          },
          "result_blockers": {"type": "array", "items": {"type": "string"}},
          "cluster_interpretation": {"type": "string", "minLength": 60},
          "boundary_and_verification": {"type": "string", "minLength": 40},
          "evidence_status": {"enum": ["metadata_only", "abstract_only", "partial_text", "full_text_main", "full_text_with_supplement"]},
          "review_status": {"enum": ["unverified", "self_checked", "cross_checked", "mentor_checked"]}
        },
        "additionalProperties": true
      }
    },
    "source_files": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["display_name", "source_path_or_url", "source_role"],
        "properties": {
          "display_name": {"type": "string", "minLength": 1},
          "source_path_or_url": {"type": "string", "minLength": 1},
          "source_role": {"type": "string", "minLength": 1}
        }
      }
    },
    "source_traces": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["canonical_literature_id", "source_title", "source_path_or_url", "source_file", "claim_id", "evidence_text", "evidence_status", "review_status"],
        "properties": {
          "canonical_literature_id": {"type": "string", "minLength": 1},
          "source_title": {"type": "string", "minLength": 1},
          "source_path_or_url": {"type": "string", "minLength": 1},
          "source_file": {"type": "string", "minLength": 1},
          "claim_id": {"type": "string", "minLength": 1},
          "evidence_text": {"type": "string", "minLength": 20},
          "location": {"type": ["string", "null"]},
          "evidence_status": {"enum": ["metadata_only", "abstract_only", "partial_text", "full_text_main", "full_text_with_supplement"]},
          "review_status": {"enum": ["unverified", "self_checked", "cross_checked", "mentor_checked"]}
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
